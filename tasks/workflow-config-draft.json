  "_shootingGuide": {
    "general": {
      "title": "通用拍摄建议",
      "sections": [
        {
          "name": "光线",
          "tips": [
            "选择明亮的室内或自然光",
            "避免强烈直射光和阴影",
            "阴天光线最柔和"
          ]
        },
        {
          "name": "背景",
          "tips": [
            "选择干净墙面或桌面",
            "避免杂乱和花纹",
            "后期会换背景，前期尽量简单"
          ]
        },
        {
          "name": "角度",
          "tips": [
            "正面拍摄，保持水平",
            "展现服装完整正面",
            "避免倾斜和变形"
          ]
        },
        {
          "name": "细节",
          "tips": [
            "领口、袖口、下摆清晰",
            "衣服展平，减少褶皱",
            "纽扣/拉链等细节可见"
          ]
        }
      ]
    }
  },

