# ─── easyuse.ai 生产环境变量 ────────────────────────────────────────────
# 复制为 .env 后填写（勿提交 .env 到 Git）

# 数据库（Supabase PostgreSQL）
# 从 Supabase Dashboard → Database → Connection String → URI 复制
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require"

# 应用对外地址（Vercel 会自动覆盖，无需手动设置）
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
