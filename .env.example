# ─── easyuse.ai 环境变量 ──────────────────────────────────────────────

# 数据库（Supabase PostgreSQL）
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres"

# Mock 模式：本地开发无数据库时设为 true
USE_MOCK=false

# AI API（不填则使用 mock 结果）
# DeepSeek:    https://api.deepseek.com/v1          deepseek-chat
# OpenAI:      https://api.openai.com/v1           gpt-4o-mini
# 通义千问:     https://dashscope.aliyuncs.com/compatible-mode/v1  qwen-plus
# MiniMax:     https://api.minimax.chat/v1        MiniMax-M2.7-highspeed
AI_API_KEY=sk-cp-xxxxxxxx
AI_BASE_URL=https://api.minimax.chat/v1
AI_MODEL=MiniMax-M2.7-highspeed

# 图片生成 Provider：mock / fal / minimax
# mock = 占位图，fal = fal.ai FLUX，minimax = MiniMax image-01
# MiniMax API Key: https://platform.minimax.io/user-center/basic-information/interface-key
IMAGE_PROVIDER=mock
IMAGE_API_KEY=
MINIMAX_API_KEY=

# 应用地址（Vercel 自动覆盖）
NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"
